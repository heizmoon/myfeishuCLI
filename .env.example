BOT_GPT_DEFAULT_MODE=text
BOT_GPT_REQUIRE_MENTION=true
BOT_GPT_SYSTEM_PROMPT=You are GPT in a Feishu group. Be concise and practical.

BOT_GEMINI_FEISHU_APP_ID=
BOT_GEMINI_FEISHU_APP_SECRET=
BOT_GEMINI_FEISHU_VERIFICATION_TOKEN=
