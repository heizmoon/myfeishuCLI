FEISHU_BOTS=gpt,gemini,painter

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

BOT_DEFAULT_PROVIDER=openai
BOT_SYSTEM_PROMPT=You are a helpful assistant in a Feishu group. Keep replies concise and practical.

HOST=0.0.0.0
PORT=8000

BOT_GPT_FEISHU_APP_ID=
BOT_GPT_FEISHU_APP_SECRET=
BOT_GPT_FEISHU_VERIFICATION_TOKEN=
