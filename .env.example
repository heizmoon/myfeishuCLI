# Optional legacy single-bot config. Leave empty if you only use named bots.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_BASE_URL=https://open.feishu.cn
FEISHU_BOTS=feifei,xiaobai

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

BOT_DEFAULT_PROVIDER=gemini
BOT_SYSTEM_PROMPT=You are a helpful assistant in a Feishu group. Keep replies concise and practical.

HOST=0.0.0.0
PORT=8000

BOT_FEIFEI_FEISHU_APP_ID=
BOT_FEIFEI_FEISHU_APP_SECRET=
BOT_FEIFEI_FEISHU_VERIFICATION_TOKEN=
BOT_FEIFEI_DEFAULT_PROVIDER=gemini
BOT_FEIFEI_DEFAULT_MODE=text
BOT_FEIFEI_REQUIRE_MENTION=true
BOT_FEIFEI_SYSTEM_PROMPT=You are Feifei, a concise Gemini assistant in a Feishu group.

BOT_XIAOBAI_FEISHU_APP_ID=
BOT_XIAOBAI_FEISHU_APP_SECRET=
BOT_XIAOBAI_FEISHU_VERIFICATION_TOKEN=
BOT_XIAOBAI_DEFAULT_PROVIDER=gemini
BOT_XIAOBAI_DEFAULT_MODE=image
BOT_XIAOBAI_REQUIRE_MENTION=true
BOT_XIAOBAI_SYSTEM_PROMPT=You are Xiaobai, a Gemini image assistant in a Feishu group.
